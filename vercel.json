{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["templates/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/shipment/:path*",
      "destination": "/api/shipment/:path*"
    }
  ],
  "routes": [
    {
      "src": "/shipment/track(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/frontend/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/frontend/icons.svg"
    },
    {
      "src": "/rider.jpg",
      "dest": "/frontend/rider.jpg"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
