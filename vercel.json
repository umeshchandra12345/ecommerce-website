{
  "functions": {
    "app/main.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api/shipment/track",
      "destination": "/app/main.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/app/main.py"
    },
    {
      "source": "/shipment/track",
      "destination": "/app/main.py"
    },
    {
      "source": "/((?!assets/|favicon.svg|icons.svg|rider.jpg).*)",
      "destination": "/index.html"
    }
  ]
}
